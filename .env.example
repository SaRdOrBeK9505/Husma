SECRET_KEY=your-secret-key-here-CHANGE-THIS
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# CORS — production da frontend domainlarini kiriting (vergul bilan ajratilgan)
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# DB_ENGINE=sqlite yoki postgresql (production da postgresql tavsiya etiladi)
DB_ENGINE=postgresql

# PostgreSQL uchun (DB_ENGINE=postgresql bo'lsa)
DATABASE_NAME=husma_db
DATABASE_USER=husma_user
DATABASE_PASSWORD=strong-password-here
DATABASE_HOST=localhost
DATABASE_PORT=5432

TELEGRAM_BOT_TOKEN=your-bot-token-here

# ===== PAYME MERCHANT API =====
# Payme Business kabinetdan olinadi. Test uchun: https://test.paycom.uz
PAYME_MERCHANT_ID=
PAYME_KEY=
# Test rejimi (sandbox). Prodga chiqishda False qiling.
PAYME_TEST_MODE=True

# ===== CLICK (keyinchalik) =====
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=
CLICK_MERCHANT_USER_ID=

# ===== MULTICARD PAYMENT GATEWAY =====
# Multicard kabinetdan olinadi: https://cabinet.multicard.uz
MULTICARD_APPLICATION_ID=
MULTICARD_SECRET=
MULTICARD_STORE_ID=
# Test rejimi (dev-mesh.multicard.uz). Prodga chiqishda False qiling.
MULTICARD_TEST_MODE=True
MULTICARD_BASE_URL=https://dev-mesh.multicard.uz
# Multicard callback URL — server-to-server to'lov natijasi
MULTICARD_CALLBACK_URL=https://yourdomain.com/api/obuna/multicard/callback/
# Multicard return URL — foydalanuvchi brauzerda qaytadigan URL
MULTICARD_RETURN_URL=https://yourdomain.com/api/obuna/multicard/return/
# HTTP timeout (sekund)
MULTICARD_TIMEOUT=15

# Frontend bazaviy URL — return view dan redirect uchun
FRONTEND_URL=https://yourdomain.com

# ===== CELERY (davriy vazifalar va asinxron ishlar) =====
# Redis broker URL (local: redis://localhost:6379/0, Docker: redis://redis:6379/0)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
